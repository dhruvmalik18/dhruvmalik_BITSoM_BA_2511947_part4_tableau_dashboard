            <column-instance column='[delivery_days]' derivation='Avg' name='[AVG(delivery_days)]' pivot='value' type='quantitative' />
            <column-instance column='[Calculation.ShippingDelayBucket]' derivation='None' name='[Calculation.ShippingDelayBucket]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />

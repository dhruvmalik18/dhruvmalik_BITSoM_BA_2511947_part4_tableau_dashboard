            <column-instance column='[profit]' derivation='Sum' name='[SUM(profit)]' pivot='value' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
      </table>
    </worksheet>
    <worksheet name='Customer Segment View'>
      <table>
        <view>
          <datasources>
            <datasource caption='dashboard_sales_data' name='federated.0abcde1.dashboardsalesdata' />
          </datasources>
          <datasource-dependencies datasource='federated.0abcde1.dashboardsalesdata'>
            <column-instance column='[customer_segment]' derivation='None' name='[customer_segment]' pivot='key' type='nominal' />
            <column-instance column='[sales]' derivation='Sum' name='[SUM(sales)]' pivot='value' type='quantitative' />

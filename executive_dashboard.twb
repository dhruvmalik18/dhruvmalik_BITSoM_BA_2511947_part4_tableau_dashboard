      <column caption='Order ID' datatype='string' name='[order_id]' role='dimension' type='nominal' />
      <column caption='Order Date' datatype='date' name='[order_date]' role='dimension' type='ordinal' />
      <column caption='Ship Date' datatype='date' name='[ship_date]' role='dimension' type='ordinal' />
      <column caption='Customer ID' datatype='string' name='[customer_id]' role='dimension' type='nominal' />
      <column caption='Customer Segment' datatype='string' name='[customer_segment]' role='dimension' type='nominal' />
      <column caption='Region' datatype='string' name='[region]' role='dimension' type='nominal' />
      <column caption='State' datatype='string' name='[state]' role='dimension' type='nominal' />
      <column caption='City' datatype='string' name='[city]' role='dimension' type='nominal' />
      <column caption='Category' datatype='string' name='[category]' role='dimension' type='nominal' />
      <column caption='Sub-Category' datatype='string' name='[sub_category]' role='dimension' type='nominal' />
      <column caption='Product Name' datatype='string' name='[product_name]' role='dimension' type='nominal' />
      <column caption='Ship Mode' datatype='string' name='[ship_mode]' role='dimension' type='nominal' />
      <column caption='Campaign Channel' datatype='string' name='[campaign_channel]' role='dimension' type='nominal' />
      <column caption='Sales' datatype='real' name='[sales]' role='measure' type='quantitative' />
      <column caption='Quantity' datatype='integer' name='[quantity]' role='measure' type='quantitative' />
      <column caption='Discount' datatype='real' name='[discount]' role='measure' type='quantitative' />
      <column caption='Profit' datatype='real' name='[profit]' role='measure' type='quantitative' />
      <column caption='Return Flag' datatype='integer' name='[return_flag]' role='measure' type='quantitative' />
      <column caption='Delivery Days' datatype='integer' name='[delivery_days]' role='measure' type='quantitative' />
      <column caption='Customer Rating' datatype='real' name='[customer_rating]' role='measure' type='quantitative' />
      <column caption='Profit Margin' datatype='real' name='[Calculation.ProfitMargin]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([sales])' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation.Cost]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[sales] - [profit]' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation.AverageOrderValue]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) / COUNTD([order_id])' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation.ReturnRate]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag]) / COUNTD([order_id])' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='string' name='[Calculation.ShippingDelayBucket]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;= 1 THEN &quot;0-1 days (Fast)&quot;
ELSEIF [delivery_days] &lt;= 3 THEN &quot;2-3 days (Standard)&quot;
ELSEIF [delivery_days] &lt;= 5 THEN &quot;4-5 days (Slow)&quot;
ELSE &quot;6+ days (Very Slow)&quot;
END' />
      </column>
      <column caption='Discount Tier' datatype='string' name='[Calculation.DiscountTier]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [discount] = 0 THEN &quot;No Discount&quot;
ELSEIF [discount] &lt;= 0.1 THEN &quot;0-10%&quot;
ELSEIF [discount] &lt;= 0.2 THEN &quot;10-20%&quot;
ELSEIF [discount] &lt;= 0.3 THEN &quot;20-30%&quot;
ELSE &quot;30%+&quot;
END' />
      </column>
      <column caption='Is Returned' datatype='string' name='[Calculation.IsReturned]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [return_flag] = 1 THEN &quot;Returned&quot; ELSE &quot;Not Returned&quot; END' />
      </column>
      <column caption='Profit Per Order' datatype='real' name='[Calculation.ProfitPerOrder]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / COUNTD([order_id])' />
      </column>
      <layout dim-percentage='0.5' measure-percentage='0.4' dim-ordering='alphabetic' measure-ordering='alphabetic' show-structure='true' />
      <semantic-values>
        <semantic-value key='[Country].[Name]' value='&quot;India&quot;' />
      </semantic-values>
    </datasource>
  </datasources>

  <worksheets>
    <worksheet name='Sales Trend'>
      <table>
        <view>
          <datasources>
            <datasource caption='dashboard_sales_data' name='federated.0abcde1.dashboardsalesdata' />
          </datasources>
          <datasource-dependencies datasource='federated.0abcde1.dashboardsalesdata'>
            <column-instance column='[order_date]' derivation='Month' name='[MONTH(order_date)]' pivot='key' type='quantitative' />
            <column-instance column='[sales]' derivation='Sum' name='[SUM(sales)]' pivot='value' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
      </table>
    </worksheet>
    <worksheet name='Regional Performance'>
      <table>
        <view>
          <datasources>
            <datasource caption='dashboard_sales_data' name='federated.0abcde1.dashboardsalesdata' />
